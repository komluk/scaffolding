# claude-home -- example config file
# Copy to ~/.claude-home.env and fill in values, or run `./install.sh` to generate interactively.
# Format: KEY=VALUE (one per line, no quotes needed, no spaces around =).

CLAUDE_HOME_TEST_BACKEND_CMD=source venv/bin/activate && pytest
CLAUDE_HOME_TEST_FRONTEND_CMD=npm run validate
CLAUDE_HOME_SONAR_PROJECT_KEY=
CLAUDE_HOME_SONAR_URL=
CLAUDE_HOME_SCHEMAS_DIR=./.scaffolding/openspec/schemas
CLAUDE_HOME_PROJECT_NAME=
CLAUDE_HOME_BACKEND_EXAMPLE_PATH=app/backend/app/feature/
CLAUDE_HOME_VENV_PATH=
