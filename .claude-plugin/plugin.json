{
  "name": "scaffolding",
  "version": "1.2.0",
  "description": "Opinionated Claude Code configuration: 30 skills, 11 agents, 14 commands, 7 hooks, spec-driven workflows. Captures the scaffolding.tool orchestration patterns.",
  "author": {
    "name": "komluk",
    "url": "https://github.com/komluk"
  },
  "homepage": "https://github.com/komluk/claude-scaffolding",
  "repository": "https://github.com/komluk/claude-scaffolding",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "agents",
    "skills",
    "workflows",
    "spec-driven",
    "orchestration"
  ],
  "agents": [
    { "name": "analyst", "path": "agents/analyst.md" },
    { "name": "architect", "path": "agents/architect.md" },
    { "name": "coordinator", "path": "agents/coordinator.md" },
    { "name": "debugger", "path": "agents/debugger.md" },
    { "name": "developer", "path": "agents/developer.md" },
    { "name": "devops", "path": "agents/devops.md" },
    { "name": "gitops", "path": "agents/gitops.md" },
    { "name": "performance-optimizer", "path": "agents/performance-optimizer.md" },
    { "name": "researcher", "path": "agents/researcher.md" },
    { "name": "reviewer", "path": "agents/reviewer.md" },
    { "name": "tech-writer", "path": "agents/tech-writer.md" }
  ],
  "skills": [
    { "name": "agent-memory", "path": "skills/agent-memory" },
    { "name": "api-design", "path": "skills/api-design" },
    { "name": "context-engineering", "path": "skills/context-engineering" },
    { "name": "database-optimization", "path": "skills/database-optimization" },
    { "name": "distill", "path": "skills/distill" },
    { "name": "docker-templates", "path": "skills/docker-templates" },
    { "name": "error-handling", "path": "skills/error-handling" },
    { "name": "git-operations", "path": "skills/git-operations" },
    { "name": "github-actions-template", "path": "skills/github-actions-template" },
    { "name": "logging-standards", "path": "skills/logging-standards" },
    { "name": "mcp-tools", "path": "skills/mcp-tools" },
    { "name": "monitoring-observability", "path": "skills/monitoring-observability" },
    { "name": "mui-styling", "path": "skills/mui-styling" },
    { "name": "pattern-recognition", "path": "skills/pattern-recognition" },
    { "name": "planning-methodology", "path": "skills/planning-methodology" },
    { "name": "python-patterns", "path": "skills/python-patterns" },
    { "name": "quality-validation", "path": "skills/quality-validation" },
    { "name": "react-patterns", "path": "skills/react-patterns" },
    { "name": "research-methodology", "path": "skills/research-methodology" },
    { "name": "security-review-checklists", "path": "skills/security-review-checklists" },
    { "name": "semantic-memory-mcp", "path": "skills/semantic-memory-mcp" },
    { "name": "spec-design", "path": "skills/spec-design" },
    { "name": "spec-develop", "path": "skills/spec-develop" },
    { "name": "spec-research", "path": "skills/spec-research" },
    { "name": "spec-review", "path": "skills/spec-review" },
    { "name": "spec-workflow", "path": "skills/spec-workflow" },
    { "name": "state-management", "path": "skills/state-management" },
    { "name": "testing-strategy", "path": "skills/testing-strategy" },
    { "name": "ui-ux-pro-max", "path": "skills/ui-ux-pro-max" },
    { "name": "worktree-management", "path": "skills/worktree-management" }
  ],
  "commands": [
    { "name": "context", "path": "commands/context.md" },
    { "name": "execute-prp", "path": "commands/execute-prp.md" },
    { "name": "generate-prp", "path": "commands/generate-prp.md" },
    { "name": "init-claude-scaffolding", "path": "commands/init-claude-scaffolding.md" },
    { "name": "init-openspec", "path": "commands/init-openspec.md" },
    { "name": "specs/apply", "path": "commands/specs/apply.md" },
    { "name": "specs/archive", "path": "commands/specs/archive.md" },
    { "name": "specs/bulk-archive", "path": "commands/specs/bulk-archive.md" },
    { "name": "specs/continue", "path": "commands/specs/continue.md" },
    { "name": "specs/explore", "path": "commands/specs/explore.md" },
    { "name": "specs/ff", "path": "commands/specs/ff.md" },
    { "name": "specs/new", "path": "commands/specs/new.md" },
    { "name": "specs/onboard", "path": "commands/specs/onboard.md" },
    { "name": "specs/sync", "path": "commands/specs/sync.md" },
    { "name": "specs/verify", "path": "commands/specs/verify.md" }
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/pre-commit-validation.sh"
          }
        ]
      },
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/block-force-push.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/file-staleness-check.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/block-env-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash(rm *)",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/block-destructive-rm.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/post-edit-review.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/file-staleness-update.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/session-start-protocol.sh"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/session-start-protocol.sh"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/session-start-protocol.sh"
          }
        ]
      }
    ]
  }
}
