{
  "name": "scaffolding",
  "version": "1.5.0",
  "description": "Opinionated Claude Code configuration: 30 skills, 11 agents, 14 commands, 7 hooks, spec-driven workflows. Captures the scaffolding.tool orchestration patterns.",
  "author": {
    "name": "komluk",
    "url": "https://github.com/komluk"
  },
  "homepage": "https://github.com/komluk/claude-scaffolding",
  "repository": "https://github.com/komluk/claude-scaffolding",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "agents",
    "skills",
    "workflows",
    "spec-driven",
    "orchestration"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/pre-commit-validation.sh"
          }
        ]
      },
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/block-force-push.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/file-staleness-check.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/block-env-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash(rm *)",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/block-destructive-rm.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/post-edit-review.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/file-staleness-update.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/session-start-protocol.sh"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/session-start-protocol.sh"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/session-start-protocol.sh"
          }
        ]
      }
    ]
  }
}
