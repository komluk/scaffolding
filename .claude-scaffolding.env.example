# claude-scaffolding -- example config file
# Copy to ~/.claude-scaffolding.env and fill in values, or run `./install.sh` to generate interactively.
# Format: KEY=VALUE (one per line, no quotes needed, no spaces around =).

CLAUDE_SCAFFOLDING_TEST_BACKEND_CMD=source venv/bin/activate && pytest
CLAUDE_SCAFFOLDING_TEST_FRONTEND_CMD=npm run validate
CLAUDE_SCAFFOLDING_SONAR_PROJECT_KEY=
CLAUDE_SCAFFOLDING_SCHEMAS_DIR=./.scaffolding/openspec/schemas
CLAUDE_SCAFFOLDING_PROJECT_NAME=
CLAUDE_SCAFFOLDING_BACKEND_EXAMPLE_PATH=app/backend/app/feature/
