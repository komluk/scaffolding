{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "1800000",
    "BASH_MAX_TIMEOUT_MS": "7200000"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Task",
      "TaskOutput",
      "WebSearch",
      "WebFetch",
      "NotebookEdit",
      "TodoWrite",
      "AskUserQuestion",
      "EnterPlanMode",
      "ExitPlanMode",
      "KillShell",
      "mcp__*",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:vitejs.dev)",
      "WebFetch(domain:mui.com)"
    ],
    "deny": [
      "Read(**/venv/**)",
      "Read(**/.venv/**)",
      "Read(**/node_modules/**)",
      "Read(**/__pycache__/**)",
      "Read(**/.mypy_cache/**)",
      "Read(**/.pytest_cache/**)",
      "Read(**/.ruff_cache/**)",
      "Read(**/.git/objects/**)",
      "Read(**/.scaffolding/conversations/**/tasks/*/output.jsonl)",
      "Glob(**/venv/**)",
      "Glob(**/.venv/**)",
      "Glob(**/node_modules/**)",
      "Grep(**/.scaffolding/conversations/**/tasks/*/output.jsonl)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Claude Code] Auto-compacting - context window full'"
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Claude Code] Manual compact triggered'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-review.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/file-staleness-update.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-validation.sh"
          }
        ]
      },
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-force-push.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/file-staleness-check.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-env-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash(rm *)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-destructive-rm.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '## Post-Compact Context Restore\n\n### Coding Rules\n- Validation: npm run validate (frontend), pytest (backend)\n- Files must stay under 500 lines\n- Types go in types/index.ts\n- scaffolding:developer owns code, scaffolding:tech-writer owns docs\n- Always Read before Edit\n- Max 200 lines per Edit operation\n\n### CRITICAL ROUTING RULES\n- NEVER use explore or general-purpose subagent types\n- ALWAYS delegate via Task(subagent_type=\"scaffolding:agent-name\", prompt=\"...\")\n- Available agents: scaffolding:architect, scaffolding:developer, scaffolding:debugger, scaffolding:reviewer, scaffolding:performance-optimizer, scaffolding:tech-writer, scaffolding:devops, scaffolding:researcher\n- Routing: Bug->scaffolding:debugger, Code/features/tests->scaffolding:developer, Architecture/complex/planning->scaffolding:architect, Docs->scaffolding:tech-writer, Review/security->scaffolding:reviewer, CI/CD->scaffolding:devops, DB/perf->scaffolding:performance-optimizer, Research->scaffolding:researcher\n- MANDATORY: Auto-route every message. No confirmation. Agent-first. NEVER edit code directly.\n'"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "description": "Claude Code settings for __CLAUDE_SCAFFOLDING_PROJECT_NAME__ - AUTONOMOUS MODE",
  "autoCompact": "instant",
  "agents": {
    "description": "Agent configuration (hooks trigger suggestions, not auto-execution)"
  },
  "validation": {
    "frontend": {
      "command": "__CLAUDE_SCAFFOLDING_TEST_FRONTEND_CMD__",
      "description": "TypeScript type-check + ESLint + Build"
    },
    "backend-python": {
      "command": "__CLAUDE_SCAFFOLDING_TEST_BACKEND_CMD__",
      "description": "Python unit tests with pytest"
    }
  },
  "shortcuts": {
    "review": "/code-review",
    "sec": "/security-review",
    "tests": "/test-coverage",
    "impl": "/implement-feature"
  }
}
